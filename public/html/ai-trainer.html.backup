<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AI Trainer - DiDio Training</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div id="aiLoadingOverlay" style="display:none;" class="loading-overlay">
    <div class="loading-spinner"></div>
    <p>L'AI sta creando il tuo piano personalizzato...</p>
  </div>

  <nav class="navbar">
    <div class="nav-brand">DiDio Training</div>
    <div class="nav-links">
      <a href="/dashboard">Dashboard</a>
      <a href="/weekly_summary">Riepilogo Settimanale</a>
      <a href="/stats">Statistiche</a>
      <button id="logoutBtn" class="btn btn-outline">Esci</button>
    </div>
  </nav>

  <main class="container">
    <h1>AI Trainer</h1>
    <h2>Il tuo Personal Trainer AI</h2>
    <p>Descrivi i tuoi obiettivi di fitness, livello di esperienza e preferenze, e l'AI creerà un piano di allenamento personalizzato per te. Il piano verrà automaticamente integrato nel tuo calendario.</p>

    <section class="ai-form-section">
      <h3>Crea il tuo piano di allenamento</h3>

      <div class="form-group">
        <label for="planType">Tipo di Piano</label>
        <select id="planType" class="form-control">
          <option value="weekly">Piano Settimanale</option>
          <option value="monthly">Piano Mensile</option>
          <option value="custom">Piano Personalizzato</option>
        </select>
      </div>

      <div class="form-group">
        <label for="fitnessLevel">Livello di Fitness</label>
        <select id="fitnessLevel" class="form-control">
          <option value="beginner">Principiante</option>
          <option value="intermediate">Intermedio</option>
          <option value="advanced">Avanzato</option>
        </select>
      </div>

      <div class="form-group">
        <label for="activityType">Tipo di Attività</label>
        <select id="activityType" class="form-control">
          <option value="">Seleziona attività (opzionale)</option>
        </select>
      </div>

      <div class="form-group">
        <label for="aiPrompt">Descrivi il tuo obiettivo</label>
        <textarea id="aiPrompt" class="form-control" rows="5"
          placeholder="Es: Voglio migliorare la resistenza cardiovascolare, mi alleno 3 volte a settimana e ho 45 minuti per sessione..."
        ></textarea>
      </div>

      <button id="generatePlanBtn" class="btn btn-primary">Genera Piano di Allenamento</button>
    </section>

    <div id="aiResponseContainer" style="display:none;">
      <h3>Il tuo piano personalizzato</h3>
      <div id="aiResponse"></div>
      <button id="saveWorkoutsBtn" class="btn btn-success">Salva Allenamenti</button>
      <button id="regenerateBtn" class="btn btn-outline">Rigenera Piano</button>
      <button id="newPlanBtn" class="btn btn-outline">Nuovo Piano</button>
    </div>

    <div id="workoutPreviewContainer" style="display:none;">
      <h3>Anteprima degli allenamenti</h3>
      <p>Verifica e personalizza i tuoi allenamenti prima di salvarli.</p>
      <div id="workoutPreviewList"></div>
      <button id="confirmSaveBtn" class="btn btn-success">Conferma e Salva</button>
      <button id="cancelSaveBtn" class="btn btn-outline">Annulla</button>
    </div>
  </main>

  <script src="/js/supabase-config.js"></script>
  <script src="/js/ai-trainer.js"></script>
</body>
</html>
